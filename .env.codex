# .env.codex

# Build + code-path semantics
# Intentionally production-like so Codex exercises production code paths.
ENV_MODE=production
PUBLIC_ENV_MODE=production

# Explicit signal this is not real prod
# PUBLIC_CODEX is what client-bundled code can see.
CODEX=true
PUBLIC_CODEX=true

# Analytics / telemetry stub
# Not used when PUBLIC_CODEX=true, but kept to avoid missing-key noise if gates change.
PUBLIC_POSTHOG_PROJECT_KEY=DUMMY
